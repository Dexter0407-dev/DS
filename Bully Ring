import java.util.Scanner;

public class Bully {
    static boolean[] active;
    static int n;
    
    public static void main (String[] args) {
        Scanner sc = new Scanner(System.in);
        
        //Input total nodes
        System.out.print("Enter the number of nodes :");
        n = sc.nextInt();
        
        active = new boolean[n + 1];
        
        //All nodes are active
        for (int i = 1; i <= n; i++) {
            active[i] = true;
        }
        
        //failed node
        System.out.println("Enter failed node: ");
        int failed = sc.nextInt();
        active[failed] = false;
        
        //Starter Node
        System.out.println("Enter node that starts Election: ");
        int starter = sc.nextInt();
        
        System.out.println("\n-----Election Started-----");
        
        election(starter);
        
        sc.close();
    }
    
    //Election Logic 
    static void election(int node) {
        boolean higherFound = false;
        
        for (int i = node + 1; i <= n; i++) {
            if (active[i]) {
                System.out.println("Node " + node + " sends election to " + i);
                higherFound = true;
                
                election(i); //higher node continues
                
                return;
            }
        }
        //No higher nide == becomes leader
        System.out.println("\n Node " + node + " becomes LEADER");
        
        for (int i = 1; i <= n; i++ ) {
            if (active[i] && i != node) {
                System.out.println("Leader " + node + " informs Node " + i);
            }
        }
    }
}
         
        
